  name: dev-app-blockuser
  namespace: kurator-system
spec:
  connectionRef:
    name: qm1
  channelName: DEV.APP.SVRCONN.0TLS
  ruleType: BLOCKUSER
  description: Deny privileged user IDs (USERLIST planned on CRD)
